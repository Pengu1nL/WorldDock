{
  "name": "@worlddock/contract",
  "version": "0.1.1",
  "description": "WorldDock push/pull contract schemas.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent-sessions": {
      "types": "./dist/agent-sessions/index.d.ts",
      "import": "./dist/agent-sessions/index.js"
    },
    "./assets": {
      "types": "./dist/assets/index.d.ts",
      "import": "./dist/assets/index.js"
    },
    "./consistency": {
      "types": "./dist/consistency/index.d.ts",
      "import": "./dist/consistency/index.js"
    },
    "./hub-api": {
      "types": "./dist/hub-api/index.d.ts",
      "import": "./dist/hub-api/index.js"
    },
    "./potential-assets": {
      "types": "./dist/potential-assets/index.d.ts",
      "import": "./dist/potential-assets/index.js"
    },
    "./releases": {
      "types": "./dist/releases/index.d.ts",
      "import": "./dist/releases/index.js"
    },
    "./world": {
      "types": "./dist/world/index.d.ts",
      "import": "./dist/world/index.js"
    },
    "./worlds/world-package": {
      "types": "./dist/worlds/world-package.d.ts",
      "import": "./dist/worlds/world-package.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "pnpm build && tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && vitest run",
    "test:pack": "pnpm build && node scripts/verify-package.mjs",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm test:pack"
  },
  "dependencies": {
    "zod": "latest"
  },
  "devDependencies": {
    "typescript": "latest",
    "vitest": "latest"
  }
}
