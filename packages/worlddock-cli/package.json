{
  "name": "@worlddock/cli",
  "version": "0.1.1",
  "description": "WorldDock local API command line tools.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "worlddock": "./dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && chmod +x dist/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:pack": "pnpm build && node scripts/verify-package.mjs",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test && pnpm test:pack"
  },
  "dependencies": {
    "@worlddock/contract": "workspace:^0.1.1"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
