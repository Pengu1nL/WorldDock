{
  "name": "@worlddock/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "prebuild": "pnpm prisma:generate",
    "build": "tsc -p tsconfig.json",
    "prelint": "pnpm prisma:generate",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "rm -rf src/generated/prisma && prisma generate --config prisma.config.ts",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "prisma:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "latest",
    "dotenv": "latest",
    "prisma": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
