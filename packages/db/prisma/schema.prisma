generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model World {
  id                String             @id @default(cuid())
  name              String
  type              String
  summary           String
  tags              String[]           @default([])
  status            String             @default("draft")
  visibility        String             @default("private")
  mode              String             @default("local")
  maturity          Int                @default(0)
  coverObjectId     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  archiveEntries    ArchiveEntry[]
  storySeeds        StorySeed[]
  conflicts         Conflict[]
  consistencyIssues ConsistencyIssue[]
  assetRelations    WorldAssetRelation[]
  agentRuns         AgentRun[]
  agentSuggestions  AgentSuggestion[]
  agentSessions     AgentSession[]
  potentialAssets   PotentialAsset[]
  officialAssets    OfficialWorldAsset[]
  officialAssetRevisions OfficialWorldAssetRevision[]
  officialAssetIndexes   OfficialWorldAssetIndex[]
  officialAssetPatches   WorldAssetPatch[]
  officialAssetBatches   WorldAssetPatchBatch[]

  @@index([coverObjectId])
  @@map("worlds")
}

model ArchiveEntry {
  id        String   @id @default(cuid())
  worldId   String
  title     String
  category  String
  summary   String
  body      String
  relations String[] @default([])
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  world     World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId])
  @@map("archive_entries")
}

model StorySeed {
  id           String   @id @default(cuid())
  worldId      String
  title        String
  hook         String
  trigger      String?
  conflict     String
  protagonists String?
  questions    String[] @default([])
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId])
  @@map("story_seeds")
}

model Conflict {
  id           String   @id @default(cuid())
  worldId      String
  title        String
  summary      String
  body         String
  related      String[] @default([])
  derivedSeeds String[] @default([])
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId])
  @@map("conflicts")
}

model ConsistencyIssue {
  id              String                 @id @default(cuid())
  worldId         String
  title           String
  description     String
  involves        String[]               @default([])
  severity        String                 @default("normal")
  status          String                 @default("open")
  subjectAssetIds String[]               @default([])
  evidence        Json                   @default("[]")
  metadata        Json                   @default("{}")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  resolvedAt      DateTime?
  world           World                  @relation(fields: [worldId], references: [id], onDelete: Cascade)
  patchBatches    WorldAssetPatchBatch[]

  @@index([worldId])
  @@index([worldId, status])
  @@map("consistency_issues")
}

model WorldAssetRelation {
  id            String   @id @default(cuid())
  worldId       String
  sourceAssetId String
  targetAssetId String
  createdAt     DateTime @default(now())
  world         World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@unique([worldId, sourceAssetId, targetAssetId])
  @@index([worldId, sourceAssetId])
  @@index([worldId, targetAssetId])
  @@map("world_asset_relations")
}

model AgentRun {
  id           String            @id @default(cuid())
  worldId      String
  status       String            @default("running")
  mode         String
  prompt       String
  model        String?
  provider     String            @default("pi")
  piSessionId  String?
  tokenUsage   Json?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  completedAt  DateTime?
  failedAt     DateTime?
  cancelledAt  DateTime?
  world        World             @relation(fields: [worldId], references: [id], onDelete: Cascade)
  events       AgentEvent[]
  suggestions  AgentSuggestion[]
  contextRefs  ContextRef[]
  potentialAssets PotentialAsset[]

  @@index([worldId])
  @@index([piSessionId])
  @@map("agent_runs")
}

model AgentEvent {
  id        String   @id @default(cuid())
  runId     String
  type      String
  sequence  Int
  payload   Json
  createdAt DateTime @default(now())
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@index([runId])
  @@map("agent_events")
}

model AgentSuggestion {
  id           String   @id @default(cuid())
  runId        String
  worldId      String
  status       String   @default("pending")
  suggestion   Json
  savedAssetId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  run          AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([worldId])
  @@map("agent_suggestions")
}

model ContextRef {
  id        String   @id @default(cuid())
  runId     String
  kind      String
  title     String
  excerpt   String
  targetId  String?
  level     String   @default("card")
  source    String   @default("initial")
  createdAt DateTime @default(now())
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([runId, level])
  @@map("context_refs")
}

model AgentSession {
  id              String                    @id @default(cuid())
  worldId         String
  kind            String
  title           String
  status          String                    @default("active")
  current         Boolean                   @default(false)
  metadata        Json                      @default("{}")
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  world           World                     @relation(fields: [worldId], references: [id], onDelete: Cascade)
  subjects        AgentSessionSubject[]
  contextItems    AgentSessionContextItem[]
  messages        AgentSessionMessage[]
  potentialAssets PotentialAsset[]
  patchBatches    WorldAssetPatchBatch[]

  @@index([worldId, kind, status])
  @@index([worldId, current])
  @@map("agent_sessions")
}

model AgentSessionSubject {
  id        String       @id @default(cuid())
  sessionId String
  kind      String
  targetId  String
  role      String       @default("primary")
  title     String?
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("agent_session_subjects")
}

model AgentSessionContextItem {
  id        String       @id @default(cuid())
  sessionId String
  kind      String
  targetId  String
  title     String?
  summary   String?
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("agent_session_context_items")
}

model AgentSessionMessage {
  id        String       @id @default(cuid())
  sessionId String
  sequence  Int
  role      String
  content   String
  status    String       @default("complete")
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
  @@index([sessionId])
  @@map("agent_session_messages")
}

model PotentialAsset {
  id              String              @id @default(cuid())
  worldId         String
  sessionId       String
  runId           String?
  type            String
  title           String
  summary         String
  evidence        Json                @default("[]")
  status          String              @default("active")
  promotedAssetId String?
  metadata        Json                @default("{}")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  world           World               @relation(fields: [worldId], references: [id], onDelete: Cascade)
  session         AgentSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  run             AgentRun?           @relation(fields: [runId], references: [id], onDelete: SetNull)
  promotedAsset   OfficialWorldAsset? @relation("PromotedPotentialAssets", fields: [promotedAssetId], references: [id], onDelete: SetNull)

  @@index([worldId, sessionId])
  @@index([worldId, type, status])
  @@index([runId])
  @@index([promotedAssetId])
  @@map("potential_assets")
}

model OfficialWorldAsset {
  id                       String                       @id @default(cuid())
  worldId                  String
  type                     String
  name                     String
  summary                  String
  documentKey              String
  status                   String                       @default("active")
  version                  Int                          @default(1)
  tags                     String[]                     @default([])
  metadata                 Json                         @default("{}")
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  archivedAt               DateTime?
  world                    World                        @relation(fields: [worldId], references: [id], onDelete: Cascade)
  revisions                OfficialWorldAssetRevision[]
  indexes                  OfficialWorldAssetIndex[]
  patches                  WorldAssetPatch[]
  promotedPotentialAssets  PotentialAsset[]             @relation("PromotedPotentialAssets")

  @@unique([worldId, documentKey])
  @@index([worldId, type, status])
  @@map("official_world_assets")
}

model OfficialWorldAssetRevision {
  id        String             @id @default(cuid())
  worldId   String
  assetId   String
  version   Int
  markdown  String
  summary   String?
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  world     World              @relation(fields: [worldId], references: [id], onDelete: Cascade)
  asset     OfficialWorldAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, version])
  @@index([worldId, assetId])
  @@map("official_world_asset_revisions")
}

model OfficialWorldAssetIndex {
  id        String             @id @default(cuid())
  worldId   String
  assetId   String
  title     String
  summary   String?
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  world     World              @relation(fields: [worldId], references: [id], onDelete: Cascade)
  asset     OfficialWorldAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([worldId, assetId])
  @@map("official_world_asset_indexes")
}

model WorldAssetPatchBatch {
  id               String            @id @default(cuid())
  worldId          String
  sessionId        String
  issueId          String?
  status           String            @default("applied")
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  appliedAt        DateTime?
  revertedAt       DateTime?
  world            World             @relation(fields: [worldId], references: [id], onDelete: Cascade)
  session          AgentSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  consistencyIssue ConsistencyIssue? @relation(fields: [issueId], references: [id], onDelete: SetNull)
  patches          WorldAssetPatch[]

  @@index([worldId, sessionId])
  @@index([worldId, status])
  @@index([issueId])
  @@map("world_asset_patch_batches")
}

model WorldAssetPatch {
  id               String                @id @default(cuid())
  worldId          String
  assetId          String
  batchId          String?
  beforeRevisionId String?
  afterRevisionId  String?
  beforeMarkdown   String
  afterMarkdown    String
  diff             String?
  assetVersionFrom Int
  assetVersionTo   Int
  status           String                @default("applied")
  metadata         Json                  @default("{}")
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  appliedAt        DateTime?
  revertedAt       DateTime?
  world            World                 @relation(fields: [worldId], references: [id], onDelete: Cascade)
  asset            OfficialWorldAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  batch            WorldAssetPatchBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([worldId, assetId])
  @@index([worldId, batchId])
  @@index([worldId, status])
  @@index([assetId, status])
  @@index([batchId])
  @@map("world_asset_patches")
}

model LocalStorageObject {
  id          String   @id @default(cuid())
  bucket      String   @default("local")
  key         String   @unique
  filePath    String
  contentType String?
  sizeBytes   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("local_storage_objects")
}

model HubConnection {
  id        String   @id @default("default")
  hubUrl    String
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hub_connections")
}
