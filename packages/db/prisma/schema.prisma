generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model World {
  id                String             @id @default(cuid())
  name              String
  type              String
  summary           String
  tags              String[]           @default([])
  status            String             @default("draft")
  visibility        String             @default("private")
  mode              String             @default("local")
  maturity          Int                @default(0)
  coverObjectId     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  archiveEntries    ArchiveEntry[]
  storySeeds        StorySeed[]
  conflicts         Conflict[]
  consistencyIssues ConsistencyIssue[]
  assetRelations    WorldAssetRelation[]
  agentRuns         AgentRun[]
  agentSuggestions  AgentSuggestion[]

  @@index([coverObjectId])
  @@map("worlds")
}

model ArchiveEntry {
  id        String   @id @default(cuid())
  worldId   String
  title     String
  category  String
  summary   String
  body      String
  relations String[] @default([])
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  world     World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId])
  @@map("archive_entries")
}

model StorySeed {
  id           String   @id @default(cuid())
  worldId      String
  title        String
  hook         String
  trigger      String?
  conflict     String
  protagonists String?
  questions    String[] @default([])
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId])
  @@map("story_seeds")
}

model Conflict {
  id           String   @id @default(cuid())
  worldId      String
  title        String
  summary      String
  body         String
  related      String[] @default([])
  derivedSeeds String[] @default([])
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId])
  @@map("conflicts")
}

model ConsistencyIssue {
  id          String   @id @default(cuid())
  worldId     String
  title       String
  description String
  involves    String[] @default([])
  severity    String   @default("normal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  world       World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId])
  @@map("consistency_issues")
}

model WorldAssetRelation {
  id            String   @id @default(cuid())
  worldId       String
  sourceAssetId String
  targetAssetId String
  createdAt     DateTime @default(now())
  world         World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@unique([worldId, sourceAssetId, targetAssetId])
  @@index([worldId, sourceAssetId])
  @@index([worldId, targetAssetId])
  @@map("world_asset_relations")
}

model AgentRun {
  id           String            @id @default(cuid())
  worldId      String
  status       String            @default("running")
  mode         String
  prompt       String
  model        String?
  provider     String            @default("openai")
  piSessionId  String?
  tokenUsage   Json?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  completedAt  DateTime?
  failedAt     DateTime?
  cancelledAt  DateTime?
  world        World             @relation(fields: [worldId], references: [id], onDelete: Cascade)
  events       AgentEvent[]
  suggestions  AgentSuggestion[]
  contextRefs  ContextRef[]

  @@index([worldId])
  @@index([piSessionId])
  @@map("agent_runs")
}

model AgentEvent {
  id        String   @id @default(cuid())
  runId     String
  type      String
  sequence  Int
  payload   Json
  createdAt DateTime @default(now())
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@index([runId])
  @@map("agent_events")
}

model AgentSuggestion {
  id           String   @id @default(cuid())
  runId        String
  worldId      String
  status       String   @default("pending")
  suggestion   Json
  savedAssetId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  run          AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([worldId])
  @@map("agent_suggestions")
}

model ContextRef {
  id        String   @id @default(cuid())
  runId     String
  kind      String
  title     String
  excerpt   String
  targetId  String?
  level     String   @default("card")
  source    String   @default("initial")
  createdAt DateTime @default(now())
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([runId, level])
  @@map("context_refs")
}

model LocalStorageObject {
  id          String   @id @default(cuid())
  bucket      String   @default("local")
  key         String   @unique
  filePath    String
  contentType String?
  sizeBytes   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("local_storage_objects")
}

model HubConnection {
  id        String   @id @default("default")
  hubUrl    String
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hub_connections")
}
