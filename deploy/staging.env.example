# WorldDock staging baseline
APP_ENV=staging
NODE_ENV=production
WORLD_DOCK_EDITION=cloud
API_HOST=0.0.0.0
API_PORT=4000
API_BODY_LIMIT_BYTES=1048576
API_RATE_LIMIT_MAX=120
TRUSTED_ORIGINS=https://staging.worlddock.example
WEB_APP_URL=https://staging.worlddock.example
DATABASE_URL=postgresql://replace
REDIS_URL=redis://replace
MEILISEARCH_HOST=https://search.staging.worlddock.example
MEILISEARCH_API_KEY=replace
S3_ENDPOINT=https://s3.staging.worlddock.example
S3_REGION=us-east-1
S3_BUCKET=worlddock-staging
S3_ACCESS_KEY_ID=replace
S3_SECRET_ACCESS_KEY=replace
S3_FORCE_PATH_STYLE=true
BETTER_AUTH_SECRET=replace_with_at_least_32_random_characters
BETTER_AUTH_URL=https://api.staging.worlddock.example
SENTRY_DSN=https://replace
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.staging.worlddock.example
OTEL_TRACES_SAMPLE_RATE=0.1
AI_PROVIDER=openai
AI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace
PI_AGENT_CORE_VERSION=
PI_AI_VERSION=
PI_MODEL_PROVIDER=
PI_MODEL_ID=
PI_PROVIDER_API_KEY=
PI_SKILLS_DIR=
