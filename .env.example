# WorldDock local development
NODE_ENV=development
APP_ENV=development

# API
API_HOST=0.0.0.0
API_PORT=4000
API_BODY_LIMIT_BYTES=1048576
API_RATE_LIMIT_MAX=120
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
TRUSTED_ORIGINS=http://localhost:3000
WEB_APP_URL=http://localhost:3000

# PostgreSQL / Prisma
DATABASE_URL=postgresql://worlddock:worlddock@localhost:5432/worlddock

# Model provider
AI_PROVIDER=openai
AI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
PI_AGENT_CORE_VERSION=
PI_AI_VERSION=
PI_MODEL_PROVIDER=
PI_MODEL_ID=
PI_PROVIDER_API_KEY=
PI_SKILLS_DIR=

# Observability
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLE_RATE=0.1
