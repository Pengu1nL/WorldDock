# WorldDock local development
NODE_ENV=development
APP_ENV=development

# API
API_HOST=0.0.0.0
API_PORT=4000
API_BODY_LIMIT_BYTES=1048576
API_RATE_LIMIT_MAX=120
TRUSTED_ORIGINS=http://localhost:3000
WEB_APP_URL=http://localhost:3000

# PostgreSQL / Prisma
DATABASE_URL=postgresql://worlddock:worlddock@localhost:5432/worlddock

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Search
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=worlddock_meili_master_key

# S3-compatible object storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=worlddock-local
S3_ACCESS_KEY_ID=worlddock
S3_SECRET_ACCESS_KEY=worlddock-secret
S3_FORCE_PATH_STYLE=true

# Auth
BETTER_AUTH_SECRET=replace_with_at_least_32_random_characters
BETTER_AUTH_URL=http://localhost:4000

# Model provider
AI_PROVIDER=mock
AI_MODEL=
PI_AGENT_CORE_VERSION=
PI_AI_VERSION=
PI_MODEL_PROVIDER=
PI_MODEL_ID=
PI_PROVIDER_API_KEY=
PI_SKILLS_DIR=

# Observability
LOG_LEVEL=info
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLE_RATE=0.1
